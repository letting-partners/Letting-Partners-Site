# Resend API key (required)
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Sender addresses ---
# FROM_EMAIL: The "From" address used for admin notification emails
FROM_EMAIL=Letting Partners <info@lettingpartners.co.uk>

# NOREPLY_EMAIL: The "From" address used for customer auto-replies
NOREPLY_EMAIL=Letting Partners <no-reply@lettingpartners.co.uk>

# Legacy aliases (still supported; FROM_EMAIL takes priority)
# RESEND_FROM=Letting Partners <no-reply@lettingpartners.co.uk>

# --- Email recipients ---
# MAIL_TO: Default recipient for all form submissions
MAIL_TO=info@lettingpartners.co.uk

# Override per form (optional — falls back to MAIL_TO if not set)
CONTACT_FORM_TO=info@lettingpartners.co.uk
TENANT_REGISTRATION_TO=info@lettingpartners.co.uk

# --- External property API (optional) ---
WEBSITE_API_KEY=
WEBSITE_API_BASE_URL=
